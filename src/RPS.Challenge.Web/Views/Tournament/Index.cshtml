@model RPS.Challenge.Web.ViewModels.TournamentPageViewModel
@{
    ViewBag.Title = "Tournament";
}

@{
    bool showRoundResults = Model.RoundResults != null && Model.RoundResults.Count > 0;
}

<div class="game-shell">
    <section class="game-hero">
        <div class="game-hero-title">Rock Paper Scissors Arena</div>
        <p class="game-hero-subtitle">Upload a bracket, launch the tournament, and watch the leaderboard evolve.</p>
    </section>

    <section class="mission-control">
        <div class="module-header">
            <h3>Mission Control</h3>
            <span id="playStatusChip" class="status-chip status-ready">Ready to play</span>
        </div>

        @using (Html.BeginForm("Play", "Tournament", FormMethod.Post, new { enctype = "multipart/form-data", onsubmit = "return markFormSubmitting();" })) {
            @Html.AntiForgeryToken()
            <ol class="round step-list step-grid">
                <li class="one control-card">
                    <h5>Step 1: Upload tournament file</h5>
                    <p>Select a <code>.txt</code> or <code>.json</code> tournament definition file.</p>
                    <input id="tournamentFile" type="file" name="tournamentFile" accept=".txt,.json" />
                </li>
                <li class="two control-card">
                    <h5>Step 2: Play tournament</h5>
                    <p>Press <strong>Play</strong> to process the tournament and reveal the champion.</p>
                    <button id="btnPlay" type="submit" class="play-button" onclick="return onActionButtonClick(this, 'Playing...');">Play tournament</button>
                    @if (!string.IsNullOrEmpty(Model.ResultMessage)) {
                        <div class="result-panel">
                            <span class="@Model.ResultMessageCssClass">@Model.ResultMessage</span>
                        </div>
                    }
                </li>
            </ol>
        }
    </section>

    <div class="tournament-dashboard">
        @if (showRoundResults) {
        <section class="round-results-section">
            <div class="module-header">
                <h3>Round timeline</h3>
                <span class="module-subtitle">Detailed results for each match and advancement</span>
            </div>

            @if (Model.RoundResults != null) {
                foreach (var round in Model.RoundResults) {
                    <div class="round-result-card">
                        <h4>Round @round.RoundNumber</h4>
                        <div class="round-summary">Matches: @round.MatchCount</div>
                        @foreach (var match in round.Matches) {
                            <div class="round-match-line">
                                @if (!match.IsBye) {
                                    <div class="round-match-versus">
                                        <div class="round-player @(match.LeftPlayerWon ? "round-player-winner" : "round-player-loser")">
                                            <span class="round-player-name">@match.LeftPlayerName</span>
                                            <span class="round-player-strategy">
                                                <span class="round-strategy-label">@match.LeftPlayerStrategy</span>
                                                <span class="round-strategy-icon" aria-hidden="true"><i class="@GetStrategyIconClass(match.LeftPlayerStrategy)"></i></span>
                                            </span>
                                        </div>
                                        <div class="round-versus-badge">VS</div>
                                        <div class="round-player @(match.RightPlayerWon ? "round-player-winner" : "round-player-loser")">
                                            <span class="round-player-name">@match.RightPlayerName</span>
                                            <span class="round-player-strategy">
                                                <span class="round-strategy-label">@match.RightPlayerStrategy</span>
                                                <span class="round-strategy-icon" aria-hidden="true"><i class="@GetStrategyIconClass(match.RightPlayerStrategy)"></i></span>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="round-match-loser-line">
                                        Winner: <span class="round-match-winner">@match.WinnerName</span>
                                    </div>
                                }
                                else {
                                    <div class="round-match-bye-line">No opponent this round — advanced to the next round</div>
                                }
                            </div>
                        }
                    </div>
                }
            }

            @if (Model.ShowChampionSummary) {
                <div class="champion-summary-section">
                    <div class="round-champion-line">
                        <div class="round-champion-left">
                            <div class="round-champion-title">Champion Crowned</div>
                            <div class="round-champion-strategy">
                                Strategy:
                                @Model.ChampionStrategy
                                <span class="round-strategy-icon" aria-hidden="true"><i class="@Model.ChampionStrategyIcon"></i></span>
                            </div>
                        </div>
                        <div class="round-champion-center">
                            <span class="round-champion-name">@Model.ChampionName</span>
                            @if (Model.ChampionPointsGained.HasValue) {
                                <span class="round-champion-points" title="Scoreboard points from this tournament">+@Model.ChampionPointsGained.Value pts</span>
                            }
                        </div>
                        <div class="round-champion-right">
                            <span class="round-champion-trophy" aria-hidden="true"><i class="fa-solid fa-trophy"></i></span>
                        </div>
                    </div>
                    @if (Model.ShowRunnerUpSummary) {
                        <div class="runner-up-summary-line">
                            <div class="round-champion-left">
                                <div class="round-champion-title">2nd place</div>
                                <div class="round-champion-strategy">
                                    Strategy:
                                    @Model.RunnerUpStrategy
                                    <span class="round-strategy-icon" aria-hidden="true"><i class="@Model.RunnerUpStrategyIcon"></i></span>
                                </div>
                            </div>
                            <div class="round-champion-center">
                                <span class="round-champion-name">@Model.RunnerUpName</span>
                                @if (Model.RunnerUpPointsGained.HasValue) {
                                    <span class="round-champion-points" title="Scoreboard points from this tournament">+@Model.RunnerUpPointsGained.Value pts</span>
                                }
                            </div>
                            <div class="round-champion-right">
                                <span class="round-champion-trophy" aria-hidden="true"><i class="fa-solid fa-medal"></i></span>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
        }

        <section class="scoreboard-section">
            <div class="module-header">
                <h3>Leaderboard</h3>
                <span class="module-subtitle">Top tournament players ranked by total points</span>
            </div>
            @using (Html.BeginForm("ResetScoreboard", "Tournament", FormMethod.Post)) {
                @Html.AntiForgeryToken()
                <button type="submit" onclick="return confirmResetAndSubmit(this);">Reset scoreboard</button>
            }

            @if (Model.Scoreboard == null || Model.Scoreboard.Count == 0) {
                <p>No scores available yet. Play a tournament to generate scores.</p>
            }
            else {
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Player Name</th>
                            <th>Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Scoreboard) {
                            var rowClass = "score-row";
                            if (row.Rank == 1) { rowClass += " score-row-first"; }
                            else if (row.Rank == 2) { rowClass += " score-row-second"; }
                            else if (row.Rank == 3) { rowClass += " score-row-third"; }

                            <tr class="@rowClass">
                                <td class="score-rank">
                                    @if (row.Rank <= 3) {
                                        <span class="score-rank-icon" aria-hidden="true"><i class="@GetRankIconClass(row.Rank)"></i></span>
                                    }
                                    @row.Rank
                                </td>
                                <td>@row.PlayerName</td>
                                <td class="score-points">@row.Points</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>
    </div>
</div>

@functions{
    private string GetStrategyIconClass(string strategy) {
        if (string.IsNullOrWhiteSpace(strategy)) {
            return "fa-solid fa-gamepad";
        }

        switch (strategy.Trim().ToLowerInvariant()) {
            case "rock":
            case "r":
                return "fa-solid fa-hand-back-fist";
            case "paper":
            case "p":
                return "fa-solid fa-hand";
            case "scissors":
            case "s":
                return "fa-solid fa-hand-scissors";
            default:
                return "fa-solid fa-gamepad";
        }
    }

    private string GetRankIconClass(int rank) {
        switch (rank) {
            case 1:
                return "fa-solid fa-medal";
            case 2:
                return "fa-solid fa-award";
            case 3:
                return "fa-solid fa-certificate";
            default:
                return string.Empty;
        }
    }
}

@section Scripts {
    <script type="text/javascript">
        var isSubmittingForm = false;

        function markFormSubmitting() {
            isSubmittingForm = true;
            return true;
        }

        function onActionButtonClick(buttonElement, loadingText) {
            if (buttonElement.disabled) {
                return false;
            }

            var statusChip = document.getElementById("playStatusChip");
            if (statusChip) {
                statusChip.className = "status-chip status-processing";
                statusChip.textContent = "Processing tournament";
            }

            var originalText = buttonElement.getAttribute("data-original-text");
            if (!originalText) {
                originalText = buttonElement.textContent;
                buttonElement.setAttribute("data-original-text", originalText);
            }

            buttonElement.textContent = loadingText;

            window.setTimeout(function () {
                if (!isSubmittingForm) {
                    buttonElement.disabled = false;
                    buttonElement.textContent = originalText;
                    if (statusChip) {
                        statusChip.className = "status-chip status-ready";
                        statusChip.textContent = "Ready to play";
                    }
                }
            }, 1200);
            return true;
        }

        function confirmResetAndSubmit(buttonElement) {
            if (!confirm("Are you sure you want to reset the scoreboard? This action cannot be undone.")) {
                return false;
            }

            return onActionButtonClick(buttonElement, "Resetting...");
        }
    </script>
}

